# Copy to .env and fill in real values — never commit .env to git

GEMINI_API_KEY=your-gemini-api-key-here
RAPIDAPI_PROXY_SECRET=your-rapidapi-proxy-secret-here
INTERNAL_SECRET=your-internal-dashboard-secret-here

MAX_PDF_SIZE_MB=10
MAX_IMAGE_SIZE_MB=5
MAX_TEXT_CHARS=12000

# Gemini 1.5-flash pricing — update if model changes
COST_PER_CALL_USD=0.001
REVENUE_PER_CALL_USD=0.08

SQLITE_DB_PATH=./data/tracker.db
LOG_LEVEL=INFO
